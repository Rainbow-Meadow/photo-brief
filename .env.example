# Public Supabase values used by the Vite app.
# Keep real local values in .env, which is ignored.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set to "true" only in CI for the photobrief.ai production build, so the
# prerendered HTML emits /cdn-cgi/image/ URLs (Cloudflare Image Resizing).
# Leave unset locally and on *.lovable.app previews.
VITE_CF_IMAGES=
