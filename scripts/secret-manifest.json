{
  "$schema": "./secret-manifest.schema.json",
  "store": "default_secrets_store",
  "_comment": "Canonical list of secrets mirrored to Cloudflare Secrets Store. `bindings` lists which Cloudflare Workers should bind each secret via wrangler.toml. Secrets with empty `bindings` are mirrored for ops/rotation only.",
  "secrets": {
    "CLOUDFLARE_API_TOKEN":       { "bindings": [], "canonical": "cloudflare" },
    "R2_ACCOUNT_ID":              { "bindings": [], "canonical": "cloudflare" },
    "R2_BUCKET_NAME":             { "bindings": [], "canonical": "cloudflare" },
    "R2_ACCESS_KEY_ID":           { "bindings": [], "canonical": "cloudflare" },
    "R2_SECRET_ACCESS_KEY":       { "bindings": [], "canonical": "cloudflare" },

    "SUPABASE_URL":               { "bindings": [], "canonical": "supabase" },
    "SUPABASE_ANON_KEY":          { "bindings": [], "canonical": "supabase" },
    "SUPABASE_PUBLISHABLE_KEY":   { "bindings": [], "canonical": "supabase" },
    "SUPABASE_PUBLISHABLE_KEYS":  { "bindings": [], "canonical": "supabase" },
    "SUPABASE_SECRET_KEYS":       { "bindings": [], "canonical": "supabase" },
    "SUPABASE_SERVICE_ROLE_KEY":  { "bindings": ["assistant-agent"], "canonical": "supabase" },
    "SUPABASE_JWKS":              { "bindings": [], "canonical": "supabase" },
    "SUPABASE_DB_URL":            { "bindings": [], "canonical": "supabase" },

    "OPENAI_API_KEY":             { "bindings": [], "canonical": "supabase" },
    "LOVABLE_API_KEY":            { "bindings": [], "canonical": "supabase" },
    "TURNSTILE_SECRET_KEY":       { "bindings": [], "canonical": "supabase" },
    "INTEGRATION_TOKEN_SECRET":   { "bindings": [], "canonical": "supabase" },
    "GOOGLE_CLIENT_ID":           { "bindings": [], "canonical": "supabase" },
    "FOUNDER_NOTIFY_EMAIL":       { "bindings": [], "canonical": "supabase" },
    "DEMO_WORKSPACE_ID":          { "bindings": [], "canonical": "supabase" }
  },
  "excluded": {
    "_comment": "Connector-managed; rotated via Lovable Connectors UI.",
    "names": [
      "GOOGLE_DRIVE_API_KEY",
      "GOOGLE_SHEETS_API_KEY",
      "GOOGLE_MAIL_API_KEY",
      "ELEVENLABS_API_KEY",
      "FIRECRAWL_API_KEY"
    ]
  }
}
