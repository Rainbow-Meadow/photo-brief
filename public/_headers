# Cloudflare Pages / compatible static-host headers.
#
# Hybrid hosting contract:
# - Cloudflare Pages serves public/prerendered marketing + discovery files.
# - Lovable/Supabase app origin serves authenticated app, admin, invite, and
#   tokenized recipient routes through the Cloudflare router Worker.
# - Do not add public cache rules for app/token HTML here.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
  X-Frame-Options: DENY

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.map
  Cache-Control: public, max-age=86400

/*.png
  Cache-Control: public, max-age=2592000

/*.jpg
  Cache-Control: public, max-age=2592000

/*.jpeg
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

/*.svg
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=2592000

/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

/icon-192.png
  Cache-Control: public, max-age=2592000

/icon-512.png
  Cache-Control: public, max-age=2592000

/
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/pricing
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/for-ai-agents
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/help
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/waitlist
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/robots.txt
  Cache-Control: public, max-age=3600, s-maxage=86400

/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=86400

/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=86400

/llms-full.txt
  Cache-Control: public, max-age=3600, s-maxage=86400

/openapi.json
  Cache-Control: public, max-age=3600, s-maxage=86400

/mcp.json
  Cache-Control: public, max-age=3600, s-maxage=86400

/.well-known/ai-plugin.json
  Cache-Control: public, max-age=3600, s-maxage=86400

/.well-known/agent.json
  Cache-Control: public, max-age=3600, s-maxage=86400
