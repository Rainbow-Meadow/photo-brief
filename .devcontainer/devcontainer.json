{
  "name": "PhotoBrief",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "enableNonRootDocker": true
    }
  },
  "containerEnv": {
    "PUPPETEER_SKIP_DOWNLOAD": "true"
  },
  "forwardPorts": [5173, 54321, 54322, 54323, 54324, 8787],
  "portsAttributes": {
    "5173": {
      "label": "PhotoBrief Vite app",
      "onAutoForward": "openPreview"
    },
    "54321": {
      "label": "Supabase local API",
      "onAutoForward": "notify"
    },
    "54322": {
      "label": "Supabase local database",
      "onAutoForward": "silent"
    },
    "54323": {
      "label": "Supabase local Studio",
      "onAutoForward": "notify"
    },
    "54324": {
      "label": "Supabase local Inbucket",
      "onAutoForward": "silent"
    },
    "8787": {
      "label": "Wrangler dev server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/start-dev.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "csstools.postcss",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "vitest.explorer"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "eslint.workingDirectories": [
          { "mode": "auto" }
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
